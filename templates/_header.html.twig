<header>
    <div class="modal fade " id="cgu" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="staticBackdropLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-xl">
            <div class="modal-content">
                <div class="modal-header">
                    <h2 class="modal-title text--primary-color text-center" id="staticBackdropLabel">{% trans %}footer.mentions_legales_cgu.titre{% endtrans %}</h2>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div>
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.preambule.titre{% endtrans %}</h3>
                        <div class="ms-2">{% trans %}footer.mentions_legales_cgu.preambule.contenu{% endtrans %}</div>
                    </div>
                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.presentation_service.titre{% endtrans %}</h3>
                        <div class="ms-2">{% trans %}footer.mentions_legales_cgu.presentation_service.contenu{% endtrans %}</div>
                    </div>
                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.acces_service.titre{% endtrans %}</h3>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.acces_service.modalites.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.acces_service.modalites.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.acces_service.disponibilite.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.acces_service.disponibilite.contenu{% endtrans %}</div>
                    </div>
                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.gestion_profil.titre{% endtrans %}</h3>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.gestion_profil.creation_compte.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.creation_compte.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.titre{% endtrans %}</h5>
                        <h6 class="text--primary-color mt-2 ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.utilisation_email.titre{% endtrans %}</h6>
                        <div class="ms-5">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.utilisation_email.contenu{% endtrans %}</div>
                        <h6 class="text--primary-color mt-2 ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.notifications.titre{% endtrans %}</h6>
                        <div class="ms-5">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.notifications.contenu{% endtrans %}</div>
                        <h6 class="text--primary-color mt-2 ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.perte_mdp.titre{% endtrans %}</h6>
                        <div class="ms-5">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.perte_mdp.contenu{% endtrans %}</div>
                        <h6 class="text--primary-color mt-2 ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.changement_mdp.titre{% endtrans %}</h6>
                        <div class="ms-5">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.changement_mdp.contenu{% endtrans %}</div>
                        <h6 class="text--primary-color mt-2 ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.consultation_donnees_compte.titre{% endtrans %}</h6>
                        <div class="ms-5">{% trans %}footer.mentions_legales_cgu.gestion_profil.gestion_compte.consultation_donnees_compte.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.gestion_profil.suppression_compte.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.gestion_profil.suppression_compte.contenu{% endtrans %}</div>
                    </div>

                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.protection_donnees.titre{% endtrans %}</h3>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.preambule.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.preambule.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.responsable_traitement.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.responsable_traitement.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.donnees_collectees.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.donnees_collectees.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.duree_conservation.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.duree_conservation.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.securite_donnees.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.securite_donnees.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.droit_acces.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.droit_acces.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.protection_donnees.gestion_traceurs.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.protection_donnees.gestion_traceurs.contenu{% endtrans %}</div>
                    </div>

                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.responsabilite.titre{% endtrans %}</h3>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.responsabilite.avertissement_contenu.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.responsabilite.avertissement_contenu.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.responsabilite.responsabilite_utilisateur.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.responsabilite.responsabilite_utilisateur.contenu{% endtrans %}</div>
                        <h5 class="text--primary-color mt-3 ms-2">{% trans %}footer.mentions_legales_cgu.responsabilite.responsabilite_am.titre{% endtrans %}</h5>
                        <div class="ms-4">{% trans %}footer.mentions_legales_cgu.responsabilite.responsabilite_am.contenu{% endtrans %}</div>
                    </div>
                    <div class="mt-3">
                        <h3 class="text--primary-color">{% trans %}footer.mentions_legales_cgu.propriete_intellectuelle.titre{% endtrans %}</h3>
                        <div class="ms-2">{% trans %}footer.mentions_legales_cgu.propriete_intellectuelle.contenu{% endtrans %}</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary btn--am-small" data-bs-dismiss="modal">{% trans %}footer.mentions_legales_cgu.fermer{% endtrans %}</button>
                </div>
            </div>
        </div>
    </div>

    <nav class="navbar navbar-expand-lg bg-white">
        <div class="container-fluid">
            <ul class="navbar-nav">
                {% set attributes_route = app.request.attributes.get('_route') %}
                {% set attributes_route_params = app.request.attributes.get('_route_params') %}
                {% if attributes_route_params is not null and attributes_route is not null %}
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            {% if app.request.locale == 'en' %}
                                <span class="fi fi-gb"></span> English
                            {% else %}
                                <span class="fi fi-fr"></span> Français
                            {% endif %}
                        </a>
                        <ul class="dropdown-menu position-absolute" style="--bs-dropdown-zindex: 2000;">
                            {% for locale in [
                                { name: 'fr', icon: 'fr' },
                                { name: 'en', icon: 'gb' },
                            ] %}
                                <li>
                                    <a href="{{ path(attributes_route, attributes_route_params|merge({_locale: locale.name})) }}" class="dropdown-item">
                                        <span class="fi fi-{{ locale.icon }}"></span>
                                        {{ locale.name|locale_name(locale.name)|capitalize }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </li>
                {% endif %}
            </ul>
            <a href="{% if app.user %}{{ path('suivi_demandes.index') }}{% else %}{{ path('homepage') }}{% endif %}" class="am-logo bg-white navbar-brand rounded-bottom d-none d-md-block mt-3">
                <span class="visually-hidden">
                    {% trans %}header.accueil{% endtrans %}
                </span>
            </a>
            <a href="{% if app.user %}{{ path('suivi_demandes.index') }}{% else %}{{ path('homepage') }}{% endif %}" class="am-logo-small bg-white navbar-brand rounded-bottom d-md-none">
                <span class="visually-hidden">
                    {% trans %}header.accueil{% endtrans %}
                </span>
            </a>
            <ul class="navbar-nav">
                <li class="nav-item d-flex align-items-center me-4 text-center">
                    <a href="{{ path('assistance') }}" class="text--primary-color">
                        {% trans %}assistance.title{% endtrans %}
                    </a>

                </li>
                {% if app.user %}
                    <li class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle" aria-hidden="true"></i>
                            <span class="d-none d-md-inline">
                                {% if app.user.demandeur %}
                                    {{ app.user.demandeur.prenom }} {{ app.user.demandeur.nom }}
                                {% else %}
                                    {{ app.user.email }}
                                {% endif %}
                            </span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end position-absolute" style="--bs-dropdown-zindex: 2000;">
                            <li>
                                <a href="{{ path('espace_informations.index') }}" class="dropdown-item">
                                    {% trans %}header.mes_informations_de_connexion{% endtrans %}
                                </a>
                            </li>
                            <li>
                                <a href="{{ path('desinscription') }}" class="dropdown-item">
                                    {% trans %}header.cloturer_espace_personnel{% endtrans %}
                                </a>
                            </li>
                            <li>
                                <a href="{{ path('deconnexion') }}" class="dropdown-item">
                                    {% trans %}header.deconnexion{% endtrans %}
                                </a>
                            </li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item" data-controller="spinner-button">
                        <a href="{{ path('connexion') }}" class="btn btn-outline--primary btn--am-small me-md-2 me-lg-2 fw-bold" role="button" data-spinner-button-target="anchor" data-action="click->spinner-button#click">
                            <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true" data-spinner-button-target="spinner"></span>
                            <span class="sr-only">{% trans %}header.deja_inscrit{% endtrans %}</span>
                        </a>
                    </li>
                {% endif %}
            </ul>
        </div>
    </nav>
</header>
